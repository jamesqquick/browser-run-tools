---
import { actions } from "astro:actions";
import Layout from "../layouts/Layout.astro";
import "../styles/tool.css";

const result = Astro.getActionResult(actions.takeScreenshot);
const inputUrl = result?.data?.url ?? "";
---

<Layout title="Screenshot - Browser Run Tools" maxWidth="720px">
  <div class="hero">
    <a class="badge" href="https://developers.cloudflare.com/browser-run/" target="_blank" rel="noopener noreferrer">Powered by Cloudflare Browser Run</a>
    <h1>Screenshot</h1>
    <p class="subtitle">
      Capture a full screenshot of any webpage using a headless browser running on Cloudflare's global network.
    </p>
  </div>

  <form method="POST" action={actions.takeScreenshot} id="screenshot-form">
    <div class="input-group">
      <label for="url-input" class="sr-only">Website URL</label>
      <input
        id="url-input"
        type="url"
        name="url"
        placeholder="https://example.com"
        required
        value={inputUrl}
        autocomplete="url"
      />
      <button type="submit" id="submit-btn">
        <span class="btn-text">Take Screenshot</span>
        <svg class="btn-spinner hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-7.07l-2.83 2.83M9.76 14.24l-2.83 2.83m12.14 0l-2.83-2.83M9.76 9.76L6.93 6.93"/>
        </svg>
      </button>
    </div>
  </form>

  {result?.error && (
    <div class="error-card">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
      <p>Failed to capture screenshot. Make sure the URL is correct and the site is publicly accessible.</p>
    </div>
  )}

  <div class="result-card hidden" id="skeleton-card">
    <div class="result-header">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
        <circle cx="8.5" cy="8.5" r="1.5"/>
        <polyline points="21 15 16 10 5 21"/>
      </svg>
      <span>Capturing screenshot...</span>
    </div>
    <div class="result-image">
      <div class="skeleton"></div>
    </div>
  </div>

  {result?.data?.image && (
    <div class="result-card" id="result-card">
      <div class="result-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
          <circle cx="8.5" cy="8.5" r="1.5"/>
          <polyline points="21 15 16 10 5 21"/>
        </svg>
        <span>Screenshot of <a href={result.data.url} target="_blank" rel="noopener noreferrer">{result.data.url}</a></span>
      </div>
      <div class="result-image">
        <div class="skeleton" id="img-skeleton"></div>
        <img
          class="hidden"
          id="screenshot-img"
          src={`data:image/png;base64,${result.data.image}`}
          alt={`Screenshot of ${result.data.url}`}
        />
      </div>
    </div>
  )}
</Layout>

<script>
  const form = document.getElementById("screenshot-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = btn.querySelector(".btn-text") as HTMLSpanElement;
  const btnSpinner = btn.querySelector(".btn-spinner") as SVGElement;
  const skeletonCard = document.getElementById("skeleton-card");

  form.addEventListener("submit", () => {
    btn.disabled = true;
    btnText.textContent = "Capturing...";
    btnSpinner.classList.remove("hidden");
    skeletonCard?.classList.remove("hidden");
  });

  const img = document.getElementById("screenshot-img") as HTMLImageElement | null;
  const imgSkeleton = document.getElementById("img-skeleton");

  if (img) {
    const reveal = () => {
      imgSkeleton?.remove();
      img.classList.remove("hidden");
    };
    if (img.complete) {
      reveal();
    } else {
      img.addEventListener("load", reveal);
      img.addEventListener("error", reveal);
    }
  }
</script>


