---
import { actions } from "astro:actions";
import Layout from "../layouts/Layout.astro";
import "../styles/tool.css";

const result = Astro.getActionResult(actions.summarizeHomepage);
const inputUrl = result?.data?.url ?? "";
---

<Layout title="Homepage Summary - Cloudflare Browser Run Demo" maxWidth="720px">
  <div class="hero">
    <a class="badge" href="https://developers.cloudflare.com/browser-run/" target="_blank" rel="noopener noreferrer">Powered by Cloudflare Browser Run</a>
    <h1>Homepage Summary</h1>
    <p class="subtitle">
      Get an AI-generated summary of what any homepage communicates to first-time visitors — see if your key messaging is coming across.
    </p>
  </div>

  <form method="POST" action={actions.summarizeHomepage} id="summary-form">
    <div class="input-group">
      <label for="url-input" class="sr-only">Website URL</label>
      <input
        id="url-input"
        type="url"
        name="url"
        placeholder="https://example.com"
        required
        value={inputUrl}
        autocomplete="url"
      />
      <button type="submit" id="submit-btn">
        <span class="btn-text">Summarize</span>
        <svg class="btn-spinner hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-7.07l-2.83 2.83M9.76 14.24l-2.83 2.83m12.14 0l-2.83-2.83M9.76 9.76L6.93 6.93"/>
        </svg>
      </button>
    </div>
  </form>

  {result?.error && (
    <div class="error-card">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
      <p>Failed to generate summary. Make sure the URL is correct and the site is publicly accessible.</p>
    </div>
  )}

  <div class="summary-card hidden" id="skeleton-card">
    <div class="summary-body">
      <div class="skeleton-text skeleton-line wide"></div>
      <div class="skeleton-text skeleton-line"></div>
      <div class="skeleton-text skeleton-line"></div>
      <div class="skeleton-text skeleton-line medium"></div>
      <div class="skeleton-text skeleton-line short"></div>
    </div>
  </div>

  {result?.data && (
    <div class="summary-card">
      <div class="summary-header">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
          <polyline points="14 2 14 8 20 8"/>
          <line x1="16" y1="13" x2="8" y2="13"/>
          <line x1="16" y1="17" x2="8" y2="17"/>
          <polyline points="10 9 9 9 8 9"/>
        </svg>
        <span>AI Summary</span>
      </div>
      <div class="summary-body">
        <p class="summary-text">{result.data.summary}</p>
      </div>
      <div class="summary-footer">
        <a class="summary-url" href={result.data.url} target="_blank" rel="noopener noreferrer">{result.data.url}</a>
      </div>
    </div>
  )}
</Layout>

<script>
  const form = document.getElementById("summary-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = btn.querySelector(".btn-text") as HTMLSpanElement;
  const btnSpinner = btn.querySelector(".btn-spinner") as SVGElement;
  const skeletonCard = document.getElementById("skeleton-card");

  form.addEventListener("submit", () => {
    btn.disabled = true;
    btnText.textContent = "Summarizing...";
    btnSpinner.classList.remove("hidden");
    skeletonCard?.classList.remove("hidden");
  });
</script>

<style>
  /* Summary Card */
  .summary-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    overflow: hidden;
  }

  .summary-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #334155;
    color: #22c55e;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .summary-body {
    padding: 1.25rem;
  }

  .summary-text {
    font-size: 1rem;
    line-height: 1.75;
    color: #cbd5e1;
  }

  .summary-footer {
    padding: 0.75rem 1.25rem;
    border-top: 1px solid #334155;
  }

  .summary-url {
    display: block;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    color: #22c55e;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .summary-url:hover { text-decoration: underline; }

  /* Skeleton */
  .skeleton-text {
    height: 1rem;
    border-radius: 6px;
    background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    margin-bottom: 0.75rem;
  }
  .skeleton-line { width: 100%; }
  .skeleton-line.wide { width: 95%; }
  .skeleton-line.medium { width: 75%; }
  .skeleton-line.short { width: 45%; margin-bottom: 0; }
</style>
