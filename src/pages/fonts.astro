---
import { actions } from "astro:actions";
import Layout from "../layouts/Layout.astro";
import "../styles/tool.css";

const result = Astro.getActionResult(actions.extractFonts);
const inputUrl = result?.data?.url ?? "";
---

<Layout title="Font Inspector - Browser Run Tools" maxWidth="720px">
  <div class="hero">
    <a class="badge" href="https://developers.cloudflare.com/browser-run/" target="_blank" rel="noopener noreferrer">Powered by Cloudflare Browser Run</a>
    <h1>Font Inspector</h1>
    <p class="subtitle">
      Discover every font used on a webpage — with weights, sizes, and usage counts.
    </p>
  </div>

  <form method="POST" action={actions.extractFonts} id="fonts-form">
    <div class="input-group">
      <label for="url-input" class="sr-only">Website URL</label>
      <input
        id="url-input"
        type="url"
        name="url"
        placeholder="https://example.com"
        required
        value={inputUrl}
        autocomplete="url"
      />
      <button type="submit" id="submit-btn">
        <span class="btn-text">Inspect Fonts</span>
        <svg class="btn-spinner hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-7.07l-2.83 2.83M9.76 14.24l-2.83 2.83m12.14 0l-2.83-2.83M9.76 9.76L6.93 6.93"/>
        </svg>
      </button>
    </div>
  </form>

  {result?.error && (
    <div class="error-card">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
      <p>Failed to inspect fonts. Make sure the URL is correct and the site is publicly accessible.</p>
    </div>
  )}

  <div class="fonts-card hidden" id="skeleton-card">
    {Array.from({ length: 3 }).map(() => (
      <div class="font-entry">
        <div class="skeleton-text" style="width: 40%; height: 1.25rem;"></div>
        <div class="skeleton-text" style="width: 80%; height: 2rem; margin-top: 0.5rem;"></div>
        <div class="skeleton-text" style="width: 60%; height: 0.8rem; margin-top: 0.5rem;"></div>
      </div>
    ))}
  </div>

  {result?.data && (
    <div class="fonts-card">
      <div class="fonts-header">
        <span class="fonts-count">{result.data.fonts.length}</span> font{result.data.fonts.length !== 1 ? "s" : ""} found on <a href={result.data.url} target="_blank" rel="noopener noreferrer">{result.data.url}</a>
      </div>

      {result.data.fonts.map((font) => (
        <div class="font-entry">
          <div class="font-name-row">
            <span class="font-name">{font.family}</span>
            <span class="font-usage">{font.count} element{font.count !== 1 ? "s" : ""}</span>
          </div>
          <div class="font-specimen" style={`font-family: '${font.family}', sans-serif;`}>
            The quick brown fox jumps over the lazy dog
          </div>
          <div class="font-meta">
            <span class="font-meta-label">Weights:</span>
            <span class="font-meta-values">{font.weights.join(", ")}</span>
          </div>
          <div class="font-meta">
            <span class="font-meta-label">Sizes:</span>
            <span class="font-meta-values">{font.sizes.join(", ")}</span>
          </div>
        </div>
      ))}

      {result.data.googleFontsUrls.length > 0 && (
        <div class="google-fonts-section">
          <div class="gf-label">Google Fonts detected</div>
          {result.data.googleFontsUrls.map((gfUrl) => (
            <a class="gf-link" href={gfUrl} target="_blank" rel="noopener noreferrer">{gfUrl}</a>
          ))}
        </div>
      )}
    </div>
  )}
</Layout>

<script>
  const form = document.getElementById("fonts-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = btn.querySelector(".btn-text") as HTMLSpanElement;
  const btnSpinner = btn.querySelector(".btn-spinner") as SVGElement;
  const skeletonCard = document.getElementById("skeleton-card");

  form.addEventListener("submit", () => {
    btn.disabled = true;
    btnText.textContent = "Inspecting...";
    btnSpinner.classList.remove("hidden");
    skeletonCard?.classList.remove("hidden");
  });
</script>

<style>
  .fonts-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    overflow: hidden;
  }

  .fonts-header {
    padding: 1rem 1.25rem;
    border-bottom: 1px solid #334155;
    font-size: 0.85rem;
    color: #94a3b8;
    font-family: "JetBrains Mono", monospace;
  }

  .fonts-count {
    color: #22c55e;
    font-weight: 700;
  }

  .fonts-header a {
    color: #22c55e;
    text-decoration: none;
  }

  .fonts-header a:hover { text-decoration: underline; }

  .font-entry {
    padding: 1.25rem;
    border-top: 1px solid #334155;
  }

  .font-entry:first-of-type {
    border-top: none;
  }

  .font-name-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .font-name {
    font-family: "JetBrains Mono", monospace;
    font-size: 1rem;
    font-weight: 600;
    color: #f8fafc;
  }

  .font-usage {
    font-size: 0.75rem;
    color: #64748b;
    white-space: nowrap;
  }

  .font-specimen {
    font-size: 1.25rem;
    color: #94a3b8;
    line-height: 1.5;
    margin-bottom: 0.75rem;
    padding: 0.75rem;
    background: #0f172a;
    border-radius: 8px;
  }

  .font-meta {
    display: flex;
    gap: 0.5rem;
    font-size: 0.75rem;
    line-height: 1.6;
  }

  .font-meta-label {
    color: #64748b;
    font-weight: 500;
    white-space: nowrap;
  }

  .font-meta-values {
    color: #94a3b8;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
  }

  .google-fonts-section {
    padding: 1rem 1.25rem;
    border-top: 1px solid #334155;
  }

  .gf-label {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #64748b;
    margin-bottom: 0.5rem;
  }

  .gf-link {
    display: block;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.7rem;
    color: #22c55e;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    line-height: 1.8;
  }

  .gf-link:hover { text-decoration: underline; }

  /* Skeleton */
  .skeleton-text {
    height: 1rem;
    border-radius: 6px;
    background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
  }
</style>
