---
import Layout from "../layouts/Layout.astro";
import { tools } from "../data/tools";
---

<Layout title="Browser Run Tools" maxWidth="900px">
  <div class="hero">
    <a class="badge" href="https://developers.cloudflare.com/browser-run/" target="_blank" rel="noopener noreferrer">Powered by Cloudflare Browser Run</a>
    <h1>Browser Run Tools</h1>
    <p class="subtitle">
      A collection of browser-based tools powered by headless Chrome running on Cloudflare's global network. Pick a tool to get started.
    </p>
  </div>

  <div class="tools-grid">
    {tools.map((tool) => (
      <a class="tool-card" href={tool.href}>
        <div class="tool-icon" set:html={tool.icon} />
        <h2>{tool.label}</h2>
        <p>{tool.description}</p>
        <span class="tool-cta">
          Try it
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </span>
      </a>
    ))}
  </div>
</Layout>

<style>
  .hero { margin-bottom: 3rem; }

  .tools-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    padding: 1.75rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms, transform 200ms;
    cursor: pointer;
  }

  .tool-card:hover {
    border-color: #22c55e;
    transform: translateY(-2px);
  }

  .tool-icon {
    display: flex;
    gap: 0.25rem;
    color: #22c55e;
    margin-bottom: 1.25rem;
  }

  .tool-card h2 {
    font-family: "JetBrains Mono", monospace;
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .tool-card p {
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.5;
    flex: 1;
    margin-bottom: 1.25rem;
  }

  .tool-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    font-weight: 600;
    color: #22c55e;
    transition: gap 200ms;
  }

  .tool-card:hover .tool-cta {
    gap: 0.625rem;
  }

  @media (max-width: 768px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
