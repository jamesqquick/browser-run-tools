---
import { actions } from "astro:actions";
import Layout from "../layouts/Layout.astro";
import "../styles/tool.css";

const result = Astro.getActionResult(actions.compareDarkLight);
const inputUrl = result?.data?.url ?? "";
---

<Layout title="Dark Mode Preview - Cloudflare Browser Run Demo">
  <div class="hero">
    <a class="badge" href="https://developers.cloudflare.com/browser-run/" target="_blank" rel="noopener noreferrer">Powered by Cloudflare Browser Run</a>
    <h1>Dark Mode Preview</h1>
    <p class="subtitle">
      Compare how any website looks in light mode and dark mode side by side — see if both color schemes render correctly.
    </p>
  </div>

  <form method="POST" action={actions.compareDarkLight} id="darkmode-form">
    <div class="input-group">
      <label for="url-input" class="sr-only">Website URL</label>
      <input
        id="url-input"
        type="url"
        name="url"
        placeholder="https://example.com"
        required
        value={inputUrl}
        autocomplete="url"
      />
      <button type="submit" id="submit-btn">
        <span class="btn-text">Compare Modes</span>
        <svg class="btn-spinner hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-7.07l-2.83 2.83M9.76 14.24l-2.83 2.83m12.14 0l-2.83-2.83M9.76 9.76L6.93 6.93"/>
        </svg>
      </button>
    </div>
  </form>

  {result?.error && (
    <div class="error-card">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
      <p>Failed to capture screenshots. Make sure the URL is correct and the site is publicly accessible.</p>
    </div>
  )}

  <div class="comparison-grid hidden" id="skeleton-grid">
    <div class="result-card">
      <div class="result-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"/>
          <line x1="12" y1="1" x2="12" y2="3"/>
          <line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/>
          <line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <span>Light Mode</span>
      </div>
      <div class="result-image"><div class="skeleton"></div></div>
    </div>
    <div class="result-card">
      <div class="result-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <span>Dark Mode</span>
      </div>
      <div class="result-image"><div class="skeleton"></div></div>
    </div>
  </div>

  {result?.data && (
    <div class="comparison-grid">
      <div class="result-card">
        <div class="result-header">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"/>
            <line x1="12" y1="1" x2="12" y2="3"/>
            <line x1="12" y1="21" x2="12" y2="23"/>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
            <line x1="1" y1="12" x2="3" y2="12"/>
            <line x1="21" y1="12" x2="23" y2="12"/>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <span>Light Mode</span>
        </div>
        <div class="result-image">
          <div class="skeleton" id="light-skeleton"></div>
          <img
            class="hidden"
            id="light-img"
            src={`data:image/png;base64,${result.data.light}`}
            alt={`Light mode screenshot of ${result.data.url}`}
          />
        </div>
      </div>
      <div class="result-card">
        <div class="result-header">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
          <span>Dark Mode</span>
        </div>
        <div class="result-image">
          <div class="skeleton" id="dark-skeleton"></div>
          <img
            class="hidden"
            id="dark-img"
            src={`data:image/png;base64,${result.data.dark}`}
            alt={`Dark mode screenshot of ${result.data.url}`}
          />
        </div>
      </div>
    </div>
  )}
</Layout>

<script>
  const form = document.getElementById("darkmode-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = btn.querySelector(".btn-text") as HTMLSpanElement;
  const btnSpinner = btn.querySelector(".btn-spinner") as SVGElement;
  const skeletonGrid = document.getElementById("skeleton-grid");

  form.addEventListener("submit", () => {
    btn.disabled = true;
    btnText.textContent = "Capturing...";
    btnSpinner.classList.remove("hidden");
    skeletonGrid?.classList.remove("hidden");
  });

  function revealImage(imgId: string, skeletonId: string) {
    const img = document.getElementById(imgId) as HTMLImageElement | null;
    const skeleton = document.getElementById(skeletonId);
    if (!img) return;
    const reveal = () => {
      skeleton?.remove();
      img.classList.remove("hidden");
    };
    if (img.complete) {
      reveal();
    } else {
      img.addEventListener("load", reveal);
      img.addEventListener("error", reveal);
    }
  }

  revealImage("light-img", "light-skeleton");
  revealImage("dark-img", "dark-skeleton");
</script>

<style>
  .subtitle { max-width: 600px; }
  form { max-width: 720px; margin-left: auto; margin-right: auto; }
  .error-card { max-width: 720px; margin-left: auto; margin-right: auto; }

  .comparison-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .comparison-grid { grid-template-columns: 1fr; }
  }
</style>
