---
import { actions } from "astro:actions";
import Layout from "../layouts/Layout.astro";
import "../styles/tool.css";

const result = Astro.getActionResult(actions.extractColors);
const inputUrl = result?.data?.url ?? "";

type ColorEntry = { hex: string; count: number };

const categories: { key: string; label: string; items: ColorEntry[] }[] = result?.data
  ? [
      { key: "backgrounds", label: "Backgrounds", items: result.data.backgrounds },
      { key: "text", label: "Text", items: result.data.text },
      { key: "accents", label: "Links & Accents", items: result.data.accents },
      { key: "borders", label: "Borders", items: result.data.borders },
    ]
  : [];
---

<Layout title="Color Palette - Cloudflare Browser Run Demo" maxWidth="720px">
  <div class="hero">
    <a class="badge" href="https://developers.cloudflare.com/browser-run/" target="_blank" rel="noopener noreferrer">Powered by Cloudflare Browser Run</a>
    <h1>Color Palette</h1>
    <p class="subtitle">
      Extract and visualize the color palette used on any webpage — grouped by backgrounds, text, accents, and borders.
    </p>
  </div>

  <form method="POST" action={actions.extractColors} id="colors-form">
    <div class="input-group">
      <label for="url-input" class="sr-only">Website URL</label>
      <input
        id="url-input"
        type="url"
        name="url"
        placeholder="https://example.com"
        required
        value={inputUrl}
        autocomplete="url"
      />
      <button type="submit" id="submit-btn">
        <span class="btn-text">Extract Colors</span>
        <svg class="btn-spinner hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-7.07l-2.83 2.83M9.76 14.24l-2.83 2.83m12.14 0l-2.83-2.83M9.76 9.76L6.93 6.93"/>
        </svg>
      </button>
    </div>
  </form>

  {result?.error && (
    <div class="error-card">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
      <p>Failed to extract colors. Make sure the URL is correct and the site is publicly accessible.</p>
    </div>
  )}

  <div class="palette-card hidden" id="skeleton-card">
    <div class="palette-section">
      <div class="skeleton-text" style="width: 30%; height: 1.1rem; margin-bottom: 1rem;"></div>
      <div class="swatch-grid">
        {Array.from({ length: 6 }).map(() => (
          <div class="swatch-skeleton">
            <div class="skeleton swatch-color-skeleton"></div>
            <div class="skeleton-text" style="width: 70%; height: 0.85rem; margin: 0.5rem auto 0.25rem;"></div>
            <div class="skeleton-text" style="width: 50%; height: 0.7rem; margin: 0 auto;"></div>
          </div>
        ))}
      </div>
    </div>
  </div>

  {result?.data && (
    <div class="palette-card">
      {categories.map((cat) => (
        <div class="palette-section">
          <div class="section-header">
            <h2>{cat.label}</h2>
            <span class="section-count">{cat.items.length} color{cat.items.length !== 1 ? "s" : ""}</span>
          </div>
          {cat.items.length > 0 ? (
            <div class="swatch-grid">
              {cat.items.map((c) => (
                <div class="swatch-item">
                  <div class="swatch-color" style={`background-color: ${c.hex};`}></div>
                  <span class="swatch-hex">{c.hex}</span>
                  <span class="swatch-count">{c.count} element{c.count !== 1 ? "s" : ""}</span>
                </div>
              ))}
            </div>
          ) : (
            <p class="section-empty">None found</p>
          )}
        </div>
      ))}
      <div class="palette-footer">
        <a class="palette-url" href={result.data.url} target="_blank" rel="noopener noreferrer">{result.data.url}</a>
      </div>
    </div>
  )}
</Layout>

<script>
  const form = document.getElementById("colors-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = btn.querySelector(".btn-text") as HTMLSpanElement;
  const btnSpinner = btn.querySelector(".btn-spinner") as SVGElement;
  const skeletonCard = document.getElementById("skeleton-card");

  form.addEventListener("submit", () => {
    btn.disabled = true;
    btnText.textContent = "Extracting...";
    btnSpinner.classList.remove("hidden");
    skeletonCard?.classList.remove("hidden");
  });
</script>

<style>
  /* Palette Card */
  .palette-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    overflow: hidden;
  }

  .palette-section {
    padding: 1.25rem;
  }

  .palette-section + .palette-section {
    border-top: 1px solid #334155;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-family: "JetBrains Mono", monospace;
    font-size: 0.95rem;
    font-weight: 600;
    color: #f8fafc;
  }

  .section-count {
    font-size: 0.8rem;
    color: #64748b;
    font-family: "JetBrains Mono", monospace;
  }

  .section-empty {
    color: #475569;
    font-style: italic;
    font-size: 0.9rem;
  }

  /* Swatch Grid */
  .swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
    gap: 0.75rem;
  }

  .swatch-item {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 8px;
    overflow: hidden;
    text-align: center;
  }

  .swatch-color {
    width: 100%;
    height: 48px;
  }

  .swatch-hex {
    display: block;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    font-weight: 600;
    color: #f8fafc;
    padding: 0.5rem 0.375rem 0.125rem;
  }

  .swatch-count {
    display: block;
    font-size: 0.7rem;
    color: #64748b;
    padding: 0 0.375rem 0.5rem;
  }

  /* Skeleton swatches */
  .swatch-skeleton {
    background: #0f172a;
    border: 1px solid #334155;
    border-radius: 8px;
    overflow: hidden;
    padding-bottom: 0.5rem;
  }

  .swatch-color-skeleton {
    width: 100%;
    height: 48px;
    aspect-ratio: unset;
    border-radius: 0;
  }

  .skeleton-text {
    height: 1rem;
    border-radius: 6px;
    background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    margin-bottom: 0.75rem;
  }

  /* Footer */
  .palette-footer {
    padding: 0.75rem 1.25rem;
    border-top: 1px solid #334155;
  }

  .palette-url {
    display: block;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    color: #22c55e;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .palette-url:hover { text-decoration: underline; }

  @media (max-width: 640px) {
    .swatch-grid {
      grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
    }
  }
</style>
