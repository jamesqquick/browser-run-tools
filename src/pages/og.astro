---
import { actions } from "astro:actions";
import Layout from "../layouts/Layout.astro";
import "../styles/tool.css";

const result = Astro.getActionResult(actions.extractOg);
const inputUrl = result?.data?.url ?? "";
---

<Layout title="OG Preview - Cloudflare Browser Run Demo" maxWidth="720px">
  <div class="hero">
    <a class="badge" href="https://developers.cloudflare.com/browser-run/" target="_blank" rel="noopener noreferrer">Powered by Cloudflare Browser Run</a>
    <h1>OG Preview</h1>
    <p class="subtitle">
      Extract the Open Graph title, description, and image from any URL — see exactly how it appears when shared on social media.
    </p>
  </div>

  <form method="POST" action={actions.extractOg} id="og-form">
    <div class="input-group">
      <label for="url-input" class="sr-only">Website URL</label>
      <input
        id="url-input"
        type="url"
        name="url"
        placeholder="https://example.com"
        required
        value={inputUrl}
        autocomplete="url"
      />
      <button type="submit" id="submit-btn">
        <span class="btn-text">Extract OG Data</span>
        <svg class="btn-spinner hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-7.07l-2.83 2.83M9.76 14.24l-2.83 2.83m12.14 0l-2.83-2.83M9.76 9.76L6.93 6.93"/>
        </svg>
      </button>
    </div>
  </form>

  {result?.error && (
    <div class="error-card">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <line x1="15" y1="9" x2="9" y2="15"/>
        <line x1="9" y1="9" x2="15" y2="15"/>
      </svg>
      <p>Failed to extract OG data. Make sure the URL is correct and the site is publicly accessible.</p>
    </div>
  )}

  <div class="og-card hidden" id="skeleton-card">
    <div class="og-image-container">
      <div class="skeleton"></div>
    </div>
    <div class="og-body">
      <div class="skeleton-text skeleton-title"></div>
      <div class="skeleton-text skeleton-desc"></div>
      <div class="skeleton-text skeleton-desc short"></div>
      <div class="skeleton-text skeleton-url"></div>
    </div>
  </div>

  {result?.data && (
    <div class="og-card">
      {result.data.image ? (
        <div class="og-image-container">
          <div class="skeleton" id="og-img-skeleton"></div>
          <img
            class="hidden"
            id="og-img"
            src={result.data.image}
            alt={result.data.title ?? "OG image"}
          />
        </div>
      ) : (
        <div class="og-no-image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
          <span>No OG image found</span>
        </div>
      )}
      <div class="og-body">
        <h2 class="og-title">{result.data.title ?? <span class="og-missing">No title found</span>}</h2>
        <p class="og-description">{result.data.description ?? <span class="og-missing">No description found</span>}</p>
        <a class="og-url" href={result.data.url} target="_blank" rel="noopener noreferrer">{result.data.url}</a>
      </div>
    </div>
  )}
</Layout>

<script>
  const form = document.getElementById("og-form") as HTMLFormElement;
  const btn = document.getElementById("submit-btn") as HTMLButtonElement;
  const btnText = btn.querySelector(".btn-text") as HTMLSpanElement;
  const btnSpinner = btn.querySelector(".btn-spinner") as SVGElement;
  const skeletonCard = document.getElementById("skeleton-card");

  form.addEventListener("submit", () => {
    btn.disabled = true;
    btnText.textContent = "Extracting...";
    btnSpinner.classList.remove("hidden");
    skeletonCard?.classList.remove("hidden");
  });

  const img = document.getElementById("og-img") as HTMLImageElement | null;
  const imgSkeleton = document.getElementById("og-img-skeleton");

  if (img) {
    const reveal = () => {
      imgSkeleton?.remove();
      img.classList.remove("hidden");
    };
    if (img.complete) {
      reveal();
    } else {
      img.addEventListener("load", reveal);
      img.addEventListener("error", reveal);
    }
  }
</script>

<style>
  /* OG Card */
  .og-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 12px;
    overflow: hidden;
  }

  .og-image-container { position: relative; }
  .og-image-container img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1200/630;
    object-fit: cover;
  }

  .og-no-image {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    aspect-ratio: 1200/630;
    background: #0f172a;
    color: #475569;
    font-size: 0.9rem;
  }

  .og-body { padding: 1.25rem; }

  .og-title {
    font-family: "IBM Plex Sans", sans-serif;
    font-size: 1.15rem;
    font-weight: 600;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    color: #f8fafc;
  }

  .og-description {
    font-size: 0.9rem;
    line-height: 1.6;
    color: #94a3b8;
    margin-bottom: 0.75rem;
  }

  .og-missing {
    color: #475569;
    font-style: italic;
  }

  .og-url {
    display: block;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.8rem;
    color: #22c55e;
    text-decoration: none;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .og-url:hover { text-decoration: underline; }

  /* OG skeleton overrides */
  .skeleton {
    aspect-ratio: 1200/630;
    border-radius: 0;
  }

  .skeleton-text {
    height: 1rem;
    border-radius: 6px;
    background: linear-gradient(90deg, #1e293b 25%, #334155 50%, #1e293b 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s ease-in-out infinite;
    margin-bottom: 0.75rem;
  }
  .skeleton-title { width: 60%; height: 1.25rem; }
  .skeleton-desc { width: 90%; }
  .skeleton-desc.short { width: 55%; }
  .skeleton-url { width: 40%; height: 0.85rem; margin-bottom: 0; }
</style>
